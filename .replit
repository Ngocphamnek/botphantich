modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "HARU Control"

[[workflows.workflow]]
name = "HARU Control"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=20130 BASE_PATH=/ pnpm --filter @workspace/admin-panel run dev"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
